[sub_resource type="CSharpScript" id="CSharpScript_4xowi"]
script/source = "using Godot;
using System;

public partial class Player : CharacterBody3D
{
	// Export variables for sensitivity and limits, adjustable in the editor
	[Export] public float MouseSensitivity = 0.005f; // Adjust as needed
	[Export] public float MinPitch = -90.0f; // degrees
	[Export] public float MaxPitch = 90.0f;  // degrees

	private Node3D _neck; // Reference to the Neck/CameraPivot node

	public override void _Ready()
	{
		// Get the neck node
		_neck = GetNode<Node3D>(\"Neck\");

		// Capture the mouse cursor to hide it and lock it to the center of the screen
		Input.MouseMode = Input.MouseModeEnum.Captured;
	}

	public override void _UnhandledInput(InputEvent @event)
	{
		if (@event is InputEventMouseMotion mouseMotion && Input.MouseMode == Input.MouseModeEnum.Captured)
		{
			// Horizontal rotation (Yaw): rotate the parent (Player) node around its Y-axis
			RotateY(-mouseMotion.Relative.X * MouseSensitivity);

			// Vertical rotation (Pitch): rotate the child (Neck) node around its X-axis
			// We use the 'neck' node so the player's y-rotation isn't affected by camera pitch
			_neck.RotateX(-mouseMotion.Relative.Y * MouseSensitivity);

			// Clamp the vertical rotation to prevent the camera from flipping over
			Vector3 neckRotation = _neck.Rotation;
			neckRotation.X = Mathf.Clamp(neckRotation.X, Mathf.DegToRad(MinPitch), Mathf.DegToRad(MaxPitch));
			_neck.Rotation = neckRotation;
		}
		else if (@event.IsActionPressed(\"ui_cancel\")) // Example: press Escape to free the mouse
		{
			Input.MouseMode = Input.MouseModeEnum.Visible;
		}
	}
}
"

